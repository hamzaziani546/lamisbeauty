APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_SITE_URL=https://lamisbeauty.site
PUBLIC_API_URL=https://api.lamisbeauty.site

DATABASE_URL=postgresql+psycopg://lamisbeauty:lamisbeauty@lamisbeauty_database:5432/lamisbeauty

GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# Path to GeoIP2 .mmdb database file (optional, uses web service if empty)
MAXMIND_DB_PATH=
# proxycheck.io API key for VPN/proxy/Tor detection (free 1000/day)
# Get one at https://proxycheck.io/dashboard
PROXYCHECK_API_KEY=
# Risk score threshold (0-100). IPs scoring >= this are blocked. 66 = "high risk"
PROXYCHECK_RISK_THRESHOLD=66
# If true, block when proxycheck.io is unreachable. If false, allow on errors.
PROXYCHECK_BLOCK_ON_ERROR=false

# Comma-separated list of allowed browser origins. Add localhost for dev,
# and any extra domain you serve the admin dashboard from.
CORS_ORIGINS=https://lamisbeauty.site,http://localhost:3000

# --- Admin dashboard ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# Long random string used to sign admin session tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_JWT_SECRET=replace-with-long-random-string
ADMIN_TOKEN_EXPIRE_HOURS=24

# --- WhatsApp order confirmation (Meta Cloud API) ---
WHATSAPP_WABA_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ORDER_TEMPLATE=new_order
WHATSAPP_ORDER_TEMPLATE_LANG=en
WHATSAPP_AUTO_CONFIRM=true
# Meta webhook — callback URL: https://api.lamisbeauty.site/webhooks/whatsapp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Chatwoot (admin WhatsApp inbox) ---
CHATWOOT_BASE_URL=https://chat.lamisbeauty.site
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# --- Sendit.ma delivery (auto-dispatch on order confirmed) ---
SENDIT_PUBLIC_KEY=
SENDIT_PRIVATE_KEY=
SENDIT_API_BASE=https://app.sendit.ma/api/v1
SENDIT_AUTO_DISPATCH=true
# Pickup city for Sendit district lookup (warehouse location)
SENDIT_PICKUP_DISTRICT=Casablanca
# Optional fixed pickup district id (skips lookup when set)
# SENDIT_PICKUP_DISTRICT_ID=
# true = ship from Sendit stock (TO_PREPARE). false = ramassage from your address (PENDING)
SENDIT_PRODUCTS_FROM_STOCK=true
# Map product_id or SKU to Sendit stock reference (from app.sendit.ma → Stock)
# SENDIT_REFERENCE_MAP={"collagen-glow-gummies":"your-ref","lutein-eye-glow-gummies":"your-ref"}
SENDIT_PACKAGING_ID=12
SENDIT_ALLOW_OPEN=1
SENDIT_ALLOW_TRY=1
